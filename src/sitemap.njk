---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.url }}/</loc>
    <lastmod>2026-04-07</lastmod>
    <changefreq>monthly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>{{ site.url }}/servicios/</loc>
    <lastmod>2026-04-07</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>{{ site.url }}/sobre-mi/</loc>
    <lastmod>2026-03-04</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  <url>
    <loc>{{ site.url }}/blog/</loc>
    {%- set latestPost = (blog | ordenarPorFecha)[0] %}
    <lastmod>{{ latestPost.date | fechaISO }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  {%- for post in blog | ordenarPorFecha %}
  <url>
    <loc>{{ site.url }}/blog/{{ post.category }}/{{ post.slug }}/</loc>
    <lastmod>{{ post.date | fechaISO }}</lastmod>
    <changefreq>yearly</changefreq>
    <priority>{% if post.category == "educacion" %}0.6{% else %}0.5{% endif %}</priority>
  </url>
  {%- endfor %}
  <url>
    <loc>{{ site.url }}/legal/privacidad/</loc>
    <lastmod>2025-06-01</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>
  <url>
    <loc>{{ site.url }}/legal/aviso-legal/</loc>
    <lastmod>2025-06-01</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>
  <url>
    <loc>{{ site.url }}/legal/condiciones/</loc>
    <lastmod>2025-06-01</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>
</urlset>
