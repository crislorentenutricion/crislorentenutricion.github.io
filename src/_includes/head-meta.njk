  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}{% if title %} — {% endif %}{{ site.name }}</title>
  <meta name="description" content="{{ description }}">
  <!-- Open Graph -->
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:title" content="{{ title }}{% if title %} — {% endif %}{{ site.name }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:image" content="{{ site.url }}{{ ogImage or site.defaultImage }}">
  <meta property="og:locale" content="es_ES">
  {% if ogType == "article" %}
  <meta property="article:published_time" content="{{ date | fechaISO }}">
  <meta property="article:author" content="Cristina Lorente Piquer">
  <meta property="article:section" content="{{ categoryLabel }}">
  {% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}{% if title %} — {% endif %}{{ site.name }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="{{ site.url }}{{ ogImage or site.defaultImage }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;1,400;1,600&family=Manrope:wght@400;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;1,400;1,600&family=Manrope:wght@400;600;700&display=swap" rel="stylesheet"></noscript>
  <link rel="stylesheet" href="/css/style.css">
  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
